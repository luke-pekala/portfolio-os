# ── Resend (email) ────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (email + analytics storage) ─────────────────
# STEP 1: Create a Google Sheet with two tabs: "Signups" and "Opens"
# STEP 2: Go to console.cloud.google.com → Create project
# STEP 3: Enable "Google Sheets API"
# STEP 4: Create a Service Account → download JSON key
# STEP 5: Share your Google Sheet with the service account email
# STEP 6: Fill in values below from the JSON key file

GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SERVICE_ACCOUNT_EMAIL=portfolio-os@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON file (keep the \n escape sequences)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# ── Admin dashboard ────────────────────────────────────────────
# Any password you choose - used to log in to /admin
ADMIN_PASSWORD=your_secure_password_here

# ── App URL ────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_URL=https://portfolio-os.vercel.app

# ── Resend sender ──────────────────────────────────────────────
# Must match a verified domain in your Resend account
# For testing, use: onboarding@resend.dev (works without domain verification)
OWNER_EMAIL=lukepekala@gmail.com
