{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/gate.js", "use": "@vercel/node" },
    { "src": "api/track.js", "use": "@vercel/node" },
    { "src": "api/admin-data.js", "use": "@vercel/node" },
    { "src": "api/deploy-notify.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/gate", "dest": "/api/gate.js" },
    { "src": "/api/track", "dest": "/api/track.js" },
    { "src": "/api/admin-data", "dest": "/api/admin-data.js" },
    { "src": "/api/deploy-notify", "dest": "/api/deploy-notify.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
